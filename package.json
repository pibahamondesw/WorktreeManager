{
  "name": "worktreemanager",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pibahamondesw/WorktreeManager.git"
  },
  "homepage": "https://github.com/pibahamondesw/WorktreeManager",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "tauri": "tauri",
    "tauri:dev:local": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "lint": "npm run lint:ts && npm run lint:rust",
    "lint:ts": "eslint src --ext .ts,.tsx && eslint eslint.config.js",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets && cargo fmt --all -- --check",
    "typecheck": "tsc -b",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{js,json,md,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{js,json,md,html}\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@linear/sdk": "^75.0.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
